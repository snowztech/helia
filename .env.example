# Helia environment. One file for both `make dev` (local Node) and
# `docker compose up` (containers).
#
#   cp .env.example .env
#   fill OPENAI_API_KEY + MASTER_KEY, then start the stack.

# ─── Required ───────────────────────────────────────────────────────────

# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# 32-byte hex key used to encrypt secrets at rest.
# Generate with: openssl rand -hex 32
MASTER_KEY=

# ─── Public URLs ────────────────────────────────────────────────────────
#
# Defaults work for `make dev` and local `docker compose up`. Only set
# these when serving Helia from a real domain behind a reverse proxy.

# Where users visit Helia. Used in verification email links.
# HELIA_WEB_URL=https://helia.example.com

# Where the browser (and embedded widget) reaches the API. Behind a proxy
# this is usually the same host as the web app.
# HELIA_API_URL=https://helia.example.com

# ─── Auth ───────────────────────────────────────────────────────────────

# "open" (default) lets anyone register and create a workspace. Flip to
# "closed" on a self-hosted instance once your team has accounts.
# HELIA_SIGNUP=open

# Email provider for verification links. If unset, links are logged to
# the api stdout — fine for self-host and local dev.
# RESEND_API_KEY=
# HELIA_EMAIL_FROM="Helia <no-reply@helia.example.com>"

# ─── Database ───────────────────────────────────────────────────────────

# `make dev` uses this to reach the Postgres container exposed on the
# host. The docker compose stack swaps this for its private network URL.
DATABASE_URL=postgresql://helia:helia@localhost:5432/helia

# Postgres password (docker stack only). Defaults to "helia".
# POSTGRES_PASSWORD=helia

# ─── Networking ─────────────────────────────────────────────────────────

# CORS allowlist. Empty = auto-allow any localhost in dev. Comma-separated
# origins for production. "*" allows any (do not use in prod).
HELIA_CORS_ORIGIN=

# API port (host-side).
PORT=4000

# Host ports for the docker stack (override if 3000/4000 are taken).
# HELIA_WEB_PORT=3000
# HELIA_API_PORT=4000
