# Helia environment. Single file for both `make dev` (local Node) and
# `docker compose up` (containers).
#
# Copy to `.env`:    cp .env.example .env
# Fill the required values below, then `make dev` or `docker compose up -d`.

# ─── Required ───────────────────────────────────────────────────────────

# OpenAI API key. https://platform.openai.com/api-keys
OPENAI_API_KEY=

# 32-byte hex key used to encrypt secrets at rest. Generate with:
#   openssl rand -hex 32
MASTER_KEY=

# ─── Database ───────────────────────────────────────────────────────────

# Used by `make dev` to connect to the Postgres container exposed on the
# host. The docker compose stack overrides this internally with
# postgresql://helia:...@postgres:5432/helia (private network).
DATABASE_URL=postgresql://helia:helia@localhost:5432/helia

# ─── Optional ───────────────────────────────────────────────────────────

# CORS allowlist. Empty = auto-allow any localhost in dev. Comma-separated
# origins for production. Set "*" to allow any (do not use in prod).
HELIA_CORS_ORIGIN=

# API port (host-side).
PORT=4000

# Postgres password (docker stack only). Defaults to "helia".
# POSTGRES_PASSWORD=helia

# Host ports for the docker stack (override if 3000/4000 are taken).
# HELIA_WEB_PORT=3000
# HELIA_API_PORT=4000

# Browser-facing URL of the API. Behind a reverse proxy, set to the host
# users visit (e.g. https://helia.example.com). Defaults to localhost:4000.
# HELIA_PUBLIC_API_URL=https://helia.example.com
