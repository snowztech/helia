# Helia self-host environment.
#
# Copy to `.env`:    cp .env.example .env
# Then fill the two required values and run: docker compose up -d

# ─── Required ───────────────────────────────────────────────────────────

# OpenAI API key. https://platform.openai.com/api-keys
OPENAI_API_KEY=

# 32-byte hex key used to encrypt secrets at rest (tool headers, future
# BYOK credentials). Generate with:
#   openssl rand -hex 32
MASTER_KEY=

# ─── Optional ───────────────────────────────────────────────────────────

# Postgres password. Defaults to "helia" — fine for local, change in prod.
# POSTGRES_PASSWORD=

# CORS allowlist for the widget. Comma-separated origins, "*" for any.
# Leave empty in dev to auto-allow any localhost origin.
# HELIA_CORS_ORIGIN=https://yourdomain.com,https://app.yourdomain.com

# Host ports — change if 3000/4000 are taken.
# HELIA_WEB_PORT=3000
# HELIA_API_PORT=4000

# Public API URL the browser reaches. Behind a reverse proxy this is the
# host users visit. Defaults to http://localhost:4000 for local stacks.
# HELIA_PUBLIC_API_URL=https://helia.yourdomain.com
