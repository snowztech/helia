# Production environment values for Helia on Railway + Neon + gethelia.dev.
#
# Copy this file to .env.production locally, fill in the placeholders,
# then paste each block into the matching Railway service's Variables tab.
#
# Do NOT commit .env.production with real values. It's gitignored.

# ─── Shared (generate these once, use everywhere needed) ────────────────

# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-REPLACE_ME

# 32-byte hex key used to encrypt secrets at rest.
# Generate: openssl rand -hex 32
MASTER_KEY=REPLACE_ME

# Neon pooled connection string (the one with `-pooler` in the hostname).
# Get it from neon.tech → your project → Connection Details → Pooled.
DATABASE_URL=postgresql://USER:PASS@ep-xxx-pooler.us-east-2.aws.neon.tech/helia?sslmode=require

# Resend API key for verification + password-reset emails. Without it,
# links are printed to the api logs (fine for staging, not for users).
# https://resend.com/api-keys
RESEND_API_KEY=re_REPLACE_ME


# ─── Railway service: "api" (apps/api) ──────────────────────────────────

DATABASE_URL=<paste from above>
OPENAI_API_KEY=<paste from above>
MASTER_KEY=<paste from above>
RESEND_API_KEY=<paste from above>

HELIA_WEB_URL=https://app.gethelia.dev
HELIA_API_URL=https://api.gethelia.dev
HELIA_CORS_ORIGIN=https://app.gethelia.dev,https://gethelia.dev
HELIA_COOKIE_DOMAIN=.gethelia.dev
HELIA_SIGNUP=open
HELIA_EMAIL_FROM=Helia <no-reply@gethelia.dev>
# "hosted" hides operator UI (provider, model, token quota) from customers.
# Self-hosters omit this so they see and control everything.
HELIA_MODE=hosted

NODE_ENV=production
PORT=4000


# ─── Railway service: "web" (apps/web) ──────────────────────────────────
# The web service never touches Postgres directly — it goes through /v1/*.
# Don't paste DATABASE_URL or OPENAI_API_KEY here.

HELIA_API_URL=https://api.gethelia.dev
HELIA_INTERNAL_API_URL=https://api.gethelia.dev

NODE_ENV=production
PORT=3000
