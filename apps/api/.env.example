# Copy this file to apps/api/.env and fill OPENAI_API_KEY.
# `make setup` does the copy for you.

# ─── Required ───────────────────────────────────────────────────────────

# OpenAI API key. Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ─── Database ───────────────────────────────────────────────────────────

# Local dev default (matches docker-compose.yml). Override in prod.
DATABASE_URL=postgresql://helia:helia@localhost:5432/helia

# ─── Server ─────────────────────────────────────────────────────────────

# Port the API listens on.
PORT=4000

# Origins allowed to make CORS requests.
#   unset           → any http://localhost:* and 127.0.0.1:* (dev convenience)
#   "a,b,c"         → comma-separated allowlist of exact origins
#   "*"             → wildcard, any origin (do not use in production)
# Example for production:
#   HELIA_CORS_ORIGIN=https://helia.snowztech.com,https://fitdistance.com
HELIA_CORS_ORIGIN=

# ─── Reserved for later phases ──────────────────────────────────────────

# Used for encrypting BYOK provider credentials. Generate with:
#   openssl rand -hex 32
MASTER_KEY=
