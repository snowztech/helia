{
  "name": "@helia/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx --env-file=../../.env --watch src/main.ts",
    "start": "tsx --env-file=../../.env src/main.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:init": "tsx scripts/db-init.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.0",
    "@helia/agent": "workspace:*",
    "@helia/db": "workspace:*",
    "@helia/rag": "workspace:*",
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.4.1",
    "ai": "^4.3.0",
    "drizzle-orm": "^0.36.0",
    "hono": "^4.6.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "postgres": "^3.4.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
