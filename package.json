{
  "name": "helia",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter @helia/api --filter @helia/web --filter @helia/widget dev",
    "dev:api": "pnpm --filter @helia/api dev",
    "dev:web": "pnpm --filter @helia/web dev",
    "dev:widget": "pnpm --filter @helia/widget dev",
    "build": "pnpm -r build",
    "start:api": "pnpm --filter @helia/api start",
    "start:web": "pnpm --filter @helia/web start",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @helia/api db:generate",
    "db:migrate": "pnpm --filter @helia/api db:migrate",
    "db:push": "pnpm --filter @helia/api db:push",
    "db:studio": "pnpm --filter @helia/api db:studio",
    "db:init": "pnpm --filter @helia/api db:init"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0"
  }
}
